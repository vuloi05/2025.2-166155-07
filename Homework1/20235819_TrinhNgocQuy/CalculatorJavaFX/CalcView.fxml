<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CalculatorJavaFX.CalcController">
   <children>
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Số 1:" />
            <TextField fx:id="firstNumber" promptText="Nhập số thứ nhất" />
         </children>
      </HBox>
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Số 2:" />
            <TextField fx:id="secondNumber" promptText="Nhập số thứ hai" />
         </children>
      </HBox>
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleAdd" text="+" />
            <Button mnemonicParsing="false" onAction="#handleSubtract" text="-" />
            <Button mnemonicParsing="false" onAction="#handleMultiply" text="*" />
            <Button mnemonicParsing="false" onAction="#handleDivide" text="/" />
         </children>
      </HBox>
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Kết quả:" />
            <TextField fx:id="calcSolution" editable="false" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
