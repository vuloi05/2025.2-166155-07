<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="calculator.controller.CalculatorController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Input Row -->
    <HBox alignment="CENTER" spacing="10">
        <Label text="Number 1:"/>
        <TextField fx:id="firstNumberField" promptText="Enter number" prefWidth="120"/>
        <ComboBox fx:id="operatorBox" prefWidth="70"/>
        <Label text="Number 2:"/>
        <TextField fx:id="secondNumberField" promptText="Enter number" prefWidth="120"/>
    </HBox>

    <!-- Button Row -->
    <HBox alignment="CENTER" spacing="10">
        <Button text="Calculate" onAction="#handleCalculate" prefWidth="120" prefHeight="35"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
    </HBox>

    <!-- Result Row -->
    <HBox alignment="CENTER" spacing="10">
        <Label text="Result:"/>
        <TextField fx:id="resultField" prefWidth="200"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
    </HBox>

</VBox>
